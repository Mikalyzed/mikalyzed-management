generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique @map("clerk_id")
  name      String
  email     String   @unique
  role      String   @default("sales")
  password  String   @default("")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  assignedVehicles Vehicle[]         @relation("CurrentAssignee")
  createdVehicles  Vehicle[]         @relation("CreatedBy")
  assignedStages   VehicleStage[]    @relation("StageAssignee")
  transportRequests TransportRequest[] @relation("RequestedBy")
  coordinatedTransports TransportRequest[] @relation("Coordinator")
  notifications    Notification[]
  activityLogs     ActivityLog[]
  calendarAssignments CalendarAssignee[]
  createdCalendarItems CalendarItem[]  @relation("CalendarCreatedBy")
  ownedEvents      Event[]           @relation("EventOwner")
  createdEvents    Event[]           @relation("EventCreatedBy")
  assignedEventTasks EventTask[]     @relation("EventTaskAssignee")
  createdContacts  Contact[]         @relation("ContactCreatedBy")
  assignedOpps     Opportunity[]     @relation("OpportunityAssignee")
  createdNotes     OpportunityNote[] @relation("NoteCreatedBy")
  assignedOppTasks OpportunityTask[] @relation("OppTaskAssignee")
  createdOppTasks  OpportunityTask[] @relation("OppTaskCreatedBy")
  activityActions  ActivityEvent[]   @relation("ActivityActor")
  assignedTasks    Task[]            @relation("TaskAssignee")
  createdTasks     Task[]            @relation("TaskCreator")
  taskApprovals    TaskApproval[]
  requestedParts   Part[]            @relation("PartRequestedBy")
  assignedParts    Part[]            @relation("PartAssignedTo")
  roundRobinWeights RoundRobinWeight[]
  dispositionLogs  DispositionLog[]
  sentMessages     Message[]         @relation("MessageSender")
  porterEntries    PorterEntry[]     @relation("PorterEntries")
  porterTasksAssigned PorterTask[]   @relation("PorterTaskAssignee")
  porterTasksCreated  PorterTask[]   @relation("PorterTaskCreator")

  @@map("users")
}

model Vehicle {
  id               String    @id @default(uuid())
  stockNumber      String    @unique @map("stock_number")
  vin              String?
  year             Int?
  make             String
  model            String
  color            String?
  trim             String?
  status           String    @default("mechanic")
  currentStageId   String?   @map("current_stage_id")
  currentAssigneeId String?  @map("current_assignee_id")
  notes            String?
  photos           String[]  @default([])
  createdById      String?   @map("created_by")
  returnQueue      Json      @default("[]") @map("return_queue")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  completedAt      DateTime? @map("completed_at")

  currentAssignee  User?     @relation("CurrentAssignee", fields: [currentAssigneeId], references: [id])
  createdBy        User?     @relation("CreatedBy", fields: [createdById], references: [id])
  stages           VehicleStage[]
  transportRequests TransportRequest[]
  calendarItems    CalendarItem[]
  opportunities    Opportunity[]    @relation("OpportunityVehicle")
  vehicleInterests VehicleInterest[] @relation("VehicleInterestVehicle")
  parts            Part[]

  @@index([status])
  @@index([currentAssigneeId])
  @@map("vehicles")
}

model Part {
  id              String    @id @default(uuid())
  vehicleId       String    @map("vehicle_id")
  name            String
  url             String?
  status          String    @default("requested") // requested, sourced, ordered, received
  requestedById   String    @map("requested_by_id")
  assignedToId    String?   @map("assigned_to_id")
  price           String?
  tracking        String?
  orderImage      String?   @map("order_image")
  expectedDelivery DateTime? @map("expected_delivery")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  requestedBy     User      @relation("PartRequestedBy", fields: [requestedById], references: [id])
  assignedTo      User?     @relation("PartAssignedTo", fields: [assignedToId], references: [id])

  @@index([vehicleId])
  @@index([status])
  @@index([requestedById])
  @@index([assignedToId])
  @@map("parts")
}

model VehicleStage {
  id                  String    @id @default(uuid())
  vehicleId           String    @map("vehicle_id")
  stage               String
  status              String    @default("pending")
  assigneeId          String?   @map("assignee_id")
  checklist           Json      @default("[]")
  notes               String?
  photos              String[]  @default([])
  dueDate             DateTime? @map("due_date")
  scopeName           String?   @map("scope_name")
  estimatedHours      Float?    @map("estimated_hours")
  startedAt           DateTime  @default(now()) @map("started_at")
  completedAt         DateTime? @map("completed_at")
  blockedAt           DateTime? @map("blocked_at")
  totalBlockedSeconds Int       @default(0) @map("total_blocked_seconds")
  priority            Int       @default(0)
  awaitingParts       Boolean   @default(false) @map("awaiting_parts")
  awaitingPartsDate   DateTime? @map("awaiting_parts_date")
  awaitingPartsSince  DateTime? @map("awaiting_parts_since")
  awaitingPartsName   String?   @map("awaiting_parts_name")
  awaitingPartsTracking String? @map("awaiting_parts_tracking")
  pauseReason         String?   @map("pause_reason")
  activeSeconds       Int       @default(0) @map("active_seconds")
  timerStartedAt      DateTime? @map("timer_started_at")
  autoPaused          Boolean   @default(false) @map("auto_paused")
  pauseDetail         String?   @map("pause_detail")
  pausedAt            DateTime? @map("paused_at")
  scheduledDate       DateTime? @map("scheduled_date")
  createdAt           DateTime  @default(now()) @map("created_at")

  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  assignee            User?     @relation("StageAssignee", fields: [assigneeId], references: [id])
  taskApprovals       TaskApproval[]

  @@index([vehicleId])
  @@index([assigneeId])
  @@index([stage, status])
  @@map("vehicle_stages")
}

model TransportRequest {
  id                 String    @id @default(uuid())
  vehicleId          String?   @map("vehicle_id")
  vehicleDescription String?   @map("vehicle_description")
  vin                String?
  trailerType        String?   @map("trailer_type") // enclosed, open
  clientName         String?   @map("client_name")
  clientPhone        String?   @map("client_phone")
  requestedById      String    @map("requested_by")
  pickupLocation     String    @map("pickup_location")
  deliveryLocation   String    @map("delivery_location")
  urgency            String    @default("standard")
  preferredDate      DateTime? @map("preferred_date")
  transportType      String?   @map("transport_type") // internal, third_party
  status             String    @default("requested")
  coordinatorId      String?   @map("coordinator_id")
  carrierInfo        String?   @map("carrier_info")
  scheduledDate      DateTime? @map("scheduled_date")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  vehicle            Vehicle?  @relation(fields: [vehicleId], references: [id])
  requestedBy        User      @relation("RequestedBy", fields: [requestedById], references: [id])
  coordinator        User?     @relation("Coordinator", fields: [coordinatorId], references: [id])

  @@index([status])
  @@index([requestedById])
  @@map("transport_requests")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String
  title      String
  message    String?
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  actorId    String?  @map("actor_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_log")
}

model ExternalRepair {
  id                String    @id @default(uuid())
  stockNumber       String    @map("stock_number")
  year              Int?
  make              String
  model             String
  color             String?
  shopName          String    @map("shop_name")
  shopPhone         String?   @map("shop_phone")
  repairDescription String    @map("repair_description")
  estimatedDays     Int?      @map("estimated_days")
  sentDate          DateTime  @map("sent_date")
  expectedReturn    DateTime? @map("expected_return")
  status            String    @default("sent") // sent, in_progress, ready, returned
  notes             String?
  followUps         Json      @default("[]") @map("follow_ups")
  createdById       String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@map("external_repairs")
}

model StageConfig {
  id                String   @id @default(uuid())
  stage             String   @unique
  defaultAssigneeId String?  @map("default_assignee_id")
  defaultChecklist  Json     @default("[]") @map("default_checklist")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("stage_config")
}

model TaskApproval {
  id              String    @id @default(uuid())
  vehicleStageId  String    @map("vehicle_stage_id")
  vehicleStage    VehicleStage @relation(fields: [vehicleStageId], references: [id], onDelete: Cascade)
  taskName        String    @map("task_name")
  additionalHours Float?    @map("additional_hours")
  tasks           Json?     @default("[]")
  requestedById   String    @map("requested_by_id")
  requestedBy     User      @relation(fields: [requestedById], references: [id])
  status          String    @default("pending")
  reviewedById    String?   @map("reviewed_by_id")
  reviewedAt      DateTime? @map("reviewed_at")
  adminNote       String?   @map("admin_note")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("task_approvals")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String    @default("content") // content, marketing, admin, operations
  status      String    @default("todo") // todo, in_progress, done
  priority    Int       @default(0) // 0=normal, 1=high, 2=urgent
  assigneeId  String?   @map("assignee_id")
  createdById String    @map("created_by_id")
  dueDate       DateTime? @map("due_date")
  scheduledDate DateTime? @map("scheduled_date")
  completedAt   DateTime? @map("completed_at")
  sortOrder     Int       @default(0) @map("sort_order")
  subtasks      Json      @default("[]") // Array of { item: string, done: boolean }
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy   User      @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([assigneeId])
  @@index([status])
  @@map("tasks_board")
}

model StageTemplate {
  id        String   @id @default(uuid())
  stage     String
  name      String
  checklist Json     @default("[]")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([stage, name])
  @@map("stage_templates")
}

// ═══ CRM ═══

model Pipeline {
  id          String   @id @default(uuid())
  name        String
  color       String   @default("#3b82f6")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  stages        PipelineStage[]
  opportunities Opportunity[]
  dispositions  Disposition[]

  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(uuid())
  pipelineId  String   @map("pipeline_id")
  name        String
  type        String   @default("open") // open, won, lost
  color       String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  dispositions  Disposition[]

  @@index([pipelineId])
  @@map("pipeline_stages")
}

model Contact {
  id             String    @id @default(uuid())
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  email          String?
  phone          String?
  secondaryPhone String?   @map("secondary_phone")
  dateOfBirth    DateTime? @map("date_of_birth")
  contactType    String    @default("lead") @map("contact_type") // lead, customer, vendor
  address        String?
  city           String?
  state          String?
  zip            String?
  country        String?
  website        String?
  timezone       String?
  source         String    @default("other")
  tags           String[]  @default([])
  notes          String?
  createdById    String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  createdBy       User?            @relation("ContactCreatedBy", fields: [createdById], references: [id])
  opportunities   Opportunity[]
  vehicleInterests VehicleInterest[]
  messages        Message[]

  @@index([email])
  @@index([phone])
  @@map("contacts")
}

model Opportunity {
  id              String    @id @default(uuid())
  contactId       String    @map("contact_id")
  pipelineId      String    @map("pipeline_id")
  stageId         String    @map("stage_id")
  assigneeId      String?   @map("assignee_id")
  vehicleId       String?   @map("vehicle_id")
  vehicleInterest String?   @map("vehicle_interest")
  source          String    @default("other")
  sourceDetail    String?   @map("source_detail")
  value           Int?      // deal value in cents
  lostReason      String?   @map("lost_reason")
  lostNotes       String?   @map("lost_notes")
  appointmentDate DateTime? @map("appointment_date")
  firstContactAt  DateTime? @map("first_contact_at")
  wonAt           DateTime? @map("won_at")
  lostAt          DateTime? @map("lost_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  contact    Contact        @relation(fields: [contactId], references: [id])
  pipeline   Pipeline       @relation(fields: [pipelineId], references: [id])
  stage      PipelineStage  @relation(fields: [stageId], references: [id])
  assignee   User?          @relation("OpportunityAssignee", fields: [assigneeId], references: [id])
  vehicle    Vehicle?       @relation("OpportunityVehicle", fields: [vehicleId], references: [id])
  tasks      OpportunityTask[]
  notes      OpportunityNote[]
  activities ActivityEvent[]
  dispositionLogs DispositionLog[]

  @@index([contactId])
  @@index([pipelineId, stageId])
  @@index([assigneeId])
  @@index([vehicleId])
  @@map("opportunities")
}

model OpportunityNote {
  id             String   @id @default(uuid())
  opportunityId  String   @map("opportunity_id")
  body           String
  createdById    String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  opportunity  Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdBy    User?       @relation("NoteCreatedBy", fields: [createdById], references: [id])

  @@index([opportunityId])
  @@map("opportunity_notes")
}

model OpportunityTask {
  id             String    @id @default(uuid())
  opportunityId  String    @map("opportunity_id")
  title          String
  dueDate        DateTime? @map("due_date")
  assigneeId     String?   @map("assignee_id")
  status         String    @default("pending") // pending, completed
  completedAt    DateTime? @map("completed_at")
  notes          String?
  createdById    String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  opportunity  Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  assignee     User?       @relation("OppTaskAssignee", fields: [assigneeId], references: [id])
  createdBy    User?       @relation("OppTaskCreatedBy", fields: [createdById], references: [id])

  @@index([opportunityId])
  @@index([assigneeId])
  @@map("opportunity_tasks")
}

model ActivityEvent {
  id             String   @id @default(uuid())
  opportunityId  String   @map("opportunity_id")
  type           String   // lead_created, stage_changed, assigned, note_added, task_created, task_completed, call_logged, sms_sent, sms_received, email_sent, appointment_set
  description    String
  metadata       Json?
  actorId        String?  @map("actor_id")
  createdAt      DateTime @default(now()) @map("created_at")

  opportunity  Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  actor        User?       @relation("ActivityActor", fields: [actorId], references: [id])

  @@index([opportunityId, createdAt])
  @@map("activity_events")
}

model VehicleInterest {
  id          String   @id @default(uuid())
  contactId   String   @map("contact_id")
  vehicleId   String?  @map("vehicle_id")
  make        String?
  model       String?
  yearMin     Int?     @map("year_min")
  yearMax     Int?     @map("year_max")
  priceMax    Int?     @map("price_max")
  createdAt   DateTime @default(now()) @map("created_at")

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  vehicle  Vehicle? @relation("VehicleInterestVehicle", fields: [vehicleId], references: [id])

  @@index([contactId])
  @@index([make, model])
  @@map("vehicle_interests")
}

model RoundRobinState {
  id              String   @id @default(uuid())
  pipelineId      String   @unique @map("pipeline_id")
  lastAssignedId  String   @map("last_assigned_id")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("round_robin_state")
}

model RoundRobinWeight {
  id         String @id @default(uuid())
  pipelineId String @map("pipeline_id")
  userId     String @map("user_id")
  weight     Int    @default(1) // e.g., 2 means gets 2x leads

  user       User   @relation(fields: [userId], references: [id])

  @@unique([pipelineId, userId])
  @@map("round_robin_weights")
}

model Disposition {
  id              String  @id @default(uuid())
  name            String
  pipelineId      String? @map("pipeline_id") // null = global
  moveToStageId   String? @map("move_to_stage_id") // optional auto-move
  followUpMinutes Int?    @map("follow_up_minutes") // optional auto follow-up
  sortOrder       Int     @default(0) @map("sort_order")
  isActive        Boolean @default(true) @map("is_active")
  color           String? // optional color for UI

  pipeline  Pipeline?      @relation(fields: [pipelineId], references: [id])
  moveToStage PipelineStage? @relation(fields: [moveToStageId], references: [id])
  logs      DispositionLog[]

  @@map("dispositions")
}

model DispositionLog {
  id              String    @id @default(uuid())
  opportunityId   String    @map("opportunity_id")
  dispositionId   String    @map("disposition_id")
  userId          String    @map("user_id")
  notes           String?
  followUpAt      DateTime? @map("follow_up_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  disposition Disposition @relation(fields: [dispositionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@index([opportunityId])
  @@index([userId])
  @@map("disposition_logs")
}

model LeadSource {
  id        String  @id @default(uuid())
  name      String  @unique // display name
  key       String  @unique // internal key like "autotrader"
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  @@map("lead_sources")
}

// ═══ Messaging ═══

model Message {
  id          String    @id @default(uuid())
  contactId   String    @map("contact_id")
  direction   String    // inbound, outbound
  channel     String    @default("sms") // sms, email, instagram, whatsapp
  body        String
  mediaUrl    String?   @map("media_url") // for MMS/images/videos
  status      String    @default("sent") // sent, delivered, failed, received
  externalId  String?   @map("external_id") // Twilio SID or external message ID
  senderId    String?   @map("sender_id") // user who sent (null for inbound)
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sender      User?     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([contactId, createdAt])
  @@index([externalId])
  @@map("messages")
}

// ═══ Porter ═══

model PorterEntry {
  id          String   @id @default(uuid())
  vin6        String   @map("vin6") // last 6 of VIN
  carName     String   @map("car_name") // e.g. "Black Camaro"
  wipeDown    Boolean  @default(false) @map("wipe_down")
  tirePressure Boolean @default(false) @map("tire_pressure")
  matUnderCar Boolean  @default(false) @map("mat_under_car")
  charger     Boolean  @default(false)
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  completedAt DateTime? @map("completed_at")
  date        DateTime @default(now()) // which day this entry is for
  porterId    String?  @map("porter_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  porter      User?    @relation("PorterEntries", fields: [porterId], references: [id])

  @@index([date])
  @@index([porterId])
  @@map("porter_entries")
}

model PorterTask {
  id          String    @id @default(uuid())
  title       String
  notes       String?
  assignedToId String?  @map("assigned_to_id")
  status      String   @default("pending") // pending, in_progress, completed
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  assignedTo  User?    @relation("PorterTaskAssignee", fields: [assignedToId], references: [id])
  createdBy   User?    @relation("PorterTaskCreator", fields: [createdById], references: [id])

  @@index([assignedToId])
  @@map("porter_tasks")
}

// ═══ Calendar ═══

model CalendarItem {
  id          String    @id @default(uuid())
  title       String
  type        String    @default("errand")
  date        DateTime
  endDate     DateTime? @map("end_date")
  allDay      Boolean   @default(false) @map("all_day")
  location    String?
  notes       String?
  status      String    @default("scheduled")
  vehicleId   String?   @map("vehicle_id")
  eventId     String?   @map("event_id")
  createdById String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])
  event       Event?    @relation(fields: [eventId], references: [id])
  createdBy   User      @relation("CalendarCreatedBy", fields: [createdById], references: [id])
  assignees   CalendarAssignee[]

  @@index([date])
  @@index([status])
  @@index([vehicleId])
  @@index([eventId])
  @@map("calendar_items")
}

model CalendarAssignee {
  id             String       @id @default(uuid())
  calendarItemId String       @map("calendar_item_id")
  userId         String       @map("user_id")
  createdAt      DateTime     @default(now()) @map("created_at")

  calendarItem   CalendarItem @relation(fields: [calendarItemId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@unique([calendarItemId, userId])
  @@map("calendar_assignees")
}

// ═══ Events ═══

model Event {
  id          String    @id @default(uuid())
  name        String
  type        String    @default("dealership_event")
  date        DateTime
  endDate     DateTime? @map("end_date")
  location    String?
  description String?
  status      String    @default("draft")
  ownerId     String    @map("owner_id")
  createdById String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner       User      @relation("EventOwner", fields: [ownerId], references: [id])
  createdBy   User      @relation("EventCreatedBy", fields: [createdById], references: [id])
  sections    EventSection[]
  calendarItems CalendarItem[]

  @@index([date])
  @@index([status])
  @@map("events")
}

model EventSection {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tasks     EventTask[]

  @@index([eventId])
  @@map("event_sections")
}

model EventTask {
  id          String    @id @default(uuid())
  sectionId   String    @map("section_id")
  title       String
  assigneeId  String?   @map("assignee_id")
  dueDate     DateTime? @map("due_date")
  priority    String    @default("normal")
  status      String    @default("pending")
  notes       String?
  sortOrder   Int       @default(0) @map("sort_order")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  section     EventSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  assignee    User?        @relation("EventTaskAssignee", fields: [assigneeId], references: [id])

  @@index([sectionId])
  @@index([assigneeId])
  @@index([status])
  @@map("event_tasks")
}

model WeeklyPlanSnapshot {
  id              String   @id @default(uuid())
  weekStart       DateTime @map("week_start")
  createdAt       DateTime @default(now()) @map("created_at")
  entries         Json     @default("[]") // Array of { vehicleStageId, vehicleId, stockNumber, year, make, model, color, day, estimatedHours, assigneeName }

  @@unique([weekStart])
  @@map("weekly_plan_snapshots")
}
